using native.string_builder as sb;

Writeln("=== StringBuilder Advanced Tests ===");

Writeln("Test 1: Chaining");
var b =: sb.builder();
sb.append(sb.append(sb.append(b, "Hello"), " "), "World");
Writeln(sb.to_string(b));

Writeln("Test 2: Building HTML");
var html =: sb.builder();
sb.append(html, "<html>");
sb.append_line(html, "");
sb.append(html, "  <body>");
sb.append_line(html, "");
sb.append(html, "    <h1>");
sb.append(html, "Welcome");
sb.append_line(html, "</h1>");
sb.append(html, "  </body>");
sb.append_line(html, "");
sb.append(html, "</html>");
Writeln(sb.to_string(html));

Writeln("Test 3: Numbers and Booleans");
var nums =: sb.builder();
sb.append(nums, "Values: ");
sb.append(nums, 42);
sb.append(nums, ", ");
sb.append(nums, 3.14);
sb.append(nums, ", ");
sb.append(nums, true);
Writeln(sb.to_string(nums));

Writeln("Test 4: Reserve and capacity");
var res =: sb.builder();
Writeln("Initial capacity: " + sb.capacity(res));
sb.reserve(res, 256);
Writeln("After reserve(256): " + sb.capacity(res));
sb.append(res, "A");
Writeln("After append: " + sb.len(res));

Writeln("Test 5: Repeated clearing");
var c =: sb.builder();
sb.append(c, "First");
Writeln(sb.to_string(c));
sb.clear(c);
sb.append(c, "Second");
Writeln(sb.to_string(c));

Writeln("All tests passed!");
