var n =: 10000;
var primes =: [];
for (var i =: 0; i < n + 1; i =: i + 1) -> primes.inject(1); <-
primes[0] =: 0;
primes[1] =: 0;
for (var p =: 2; p * p <= n; p =: p + 1) ->
    if (primes[p] ?= 1) ->
        for (var i =: p * p; i <= n; i =: i + p) ->
            primes[i] =: 0;
        <-
    <-
<-
var count =: 0;
for (var i =: 0; i <= n; i =: i + 1) ->
    if (primes[i] ?= 1) -> count =: count + 1; <-
<-
Writeln(count);
