var n =: 500;
var arr =: [];
for (var i =: 0; i < n; i =: i + 1) -> arr.inject(n - i); <-

for (var i =: 0; i < n; i =: i + 1) ->
    for (var j =: 0; j < n - i - 1; j =: j + 1) ->
        if (arr[j] > arr[j + 1]) ->
            var tmp =: arr[j];
            arr[j] =: arr[j+1];
            arr[j+1] =: tmp;
        <-
    <-
<-
Writeln(arr[0], arr[n-1]);
