using std.math as math;
Writeln(math.abs(-5));
Writeln(math.abs(0));
Writeln(math.square(4));
Writeln(math.min(10, 3));
Writeln(math.max(10, 3));
Writeln(math.sqr(5));
Writeln(math.mod(10, 4));
Writeln(math.floor(math.PI()));
Writeln(math.round(math.deg(math.PI())));
Writeln(math.rad(180) ?= math.PI());
Writeln(math.isnan(0));
Writeln(math.isinf(0));
